#!/usr/bin/env bash
# ── Laravel + Inertia.js ({{ starter_kit | title }}) bootstrap script ──────────────────
# Generated by Laravel Dockerized Installer
#
# Prerequisites (macOS / Linux):
#   - PHP >= 8.2  (https://php.net)
#   - Composer    (https://getcomposer.org)
#   - Node.js >= 20 + npm (https://nodejs.org)
#   - Docker + Docker Compose (for the Docker stack)
#
# Usage:
#   chmod +x bootstrap.sh
#   ./bootstrap.sh           # creates ./{{ app_name | lower | replace(' ', '-') }} and the Docker files
# ─────────────────────────────────────────────────────────────────────────────
set -euo pipefail

APP_DIR="{{ app_name | lower | replace(' ', '-') }}"
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# ── 1. Install the Laravel installer globally ────────────────────────────────
echo "==> Installing laravel/installer globally via Composer..."
composer global require laravel/installer --no-interaction -q

{% if install_boost %}
echo "==> Installing laravel/boost (AI coding assistant)..."
composer global require laravel/boost --dev --no-interaction -q
{% endif %}

# Ensure Composer's global bin is on PATH
export PATH="$PATH:$HOME/.composer/vendor/bin:$HOME/.config/composer/vendor/bin"

if ! command -v laravel &>/dev/null; then
    echo "ERROR: 'laravel' binary not found. Add Composer's global bin to your PATH." >&2
    echo "  Run: export PATH=\"\$PATH:\$(composer global config bin-dir --absolute)\"" >&2
    exit 1
fi

# ── 2. Create the Laravel application ───────────────────────────────────────
echo "==> Creating Laravel application '${APP_DIR}' with Inertia.js ({{ starter_kit | title }})..."
laravel new "${APP_DIR}" \
{% if starter_kit == 'react' %}
    --react \
{% elif starter_kit == 'vue' %}
    --vue \
{% elif starter_kit == 'livewire' %}
    --livewire \
{% elif starter_kit == 'livewire-class-components' %}
    --livewire-class-components \
{% endif %}
{% if auth_provider == 'workos' %}
    --workos \
{% endif %}
{% if teams %}
    --teams \
{% endif %}
{% if testing_framework == 'pest' %}
    --pest \
{% else %}
    --phpunit \
{% endif %}
{% if install_boost %}
    --boost \
{% else %}
    --no-boost \
{% endif %}
    --no-interaction

# ── 3. Install npm dependencies ──────────────────────────────────────────────
echo "==> Installing npm dependencies..."
(cd "${APP_DIR}" && npm install)

# ── 4. Copy Docker scaffold files into the new project ──────────────────────
echo "==> Copying Docker scaffold into '${APP_DIR}'..."
cp "${SCRIPT_DIR}/Dockerfile"         "${APP_DIR}/Dockerfile"
cp "${SCRIPT_DIR}/docker-compose.yml" "${APP_DIR}/docker-compose.yml"
cp "${SCRIPT_DIR}/.env.docker"        "${APP_DIR}/.env.docker"

echo ""
echo "✅  Done! Laravel + Inertia.js ({{ starter_kit | title }}) project created in ./${APP_DIR}"
echo ""
echo "Next steps:"
echo "  cd ${APP_DIR}"
echo "  cp .env.docker .env"
echo "  docker compose up --build"
echo ""
echo "  App:   http://localhost:{{ app_port }}"
echo "  Vite:  http://localhost:5173"
