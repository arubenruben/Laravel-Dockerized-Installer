FROM php:{{ php_version }}-cli-alpine

RUN apk add --no-cache \
    bash curl zip unzip git libpng-dev libjpeg-turbo-dev freetype-dev \
    oniguruma-dev libxml2-dev && \
    docker-php-ext-configure gd --with-freetype --with-jpeg && \
{% if db == 'mysql' %}
    docker-php-ext-install pdo pdo_mysql mbstring gd xml bcmath opcache
{% elif db == 'postgres' %}
    apk add --no-cache postgresql-dev && \
    docker-php-ext-install pdo pdo_pgsql mbstring gd xml bcmath opcache
{% else %}
    apk add --no-cache sqlite-dev && \
    docker-php-ext-install pdo pdo_sqlite mbstring gd xml bcmath opcache
{% endif %}

COPY --from=composer:2 /usr/bin/composer /usr/bin/composer

WORKDIR /var/www/html
COPY . .

# Make the entrypoint executable; storage/bootstrap dirs are created by
# the entrypoint at runtime after the volume mount is in place.
RUN chmod +x entrypoint.sh

EXPOSE 8000
CMD ["./entrypoint.sh"]
