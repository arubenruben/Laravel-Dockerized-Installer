#!/bin/sh
# Laravel + Inertia.js — Docker entrypoint (stage/prod)
# Generated by Laravel Dockerized Installer
set -e

{% if db == 'sqlite' %}
# ── 1. Ensure the SQLite database file exists ────────────────────────────────
mkdir -p database
touch database/database.sqlite

# ── 2. Run migrations ─────────────────────────────────────────────────────────
echo "==> Running database migrations..."
php artisan migrate --force --no-interaction

{% else %}
# ── 1 & 2. Wait for the database, then migrate ────────────────────────────────
echo "==> Waiting for the database to be ready..."
MAX_RETRIES=30
ATTEMPT=0
until php artisan migrate --force --no-interaction; do
    ATTEMPT=$((ATTEMPT + 1))
    if [ "$ATTEMPT" -ge "$MAX_RETRIES" ]; then
        echo "ERROR: Database not reachable after ${MAX_RETRIES} attempts. Exiting."
        exit 1
    fi
    echo "    Not ready yet, retrying in 3 s... (${ATTEMPT}/${MAX_RETRIES})"
    sleep 3
done

{% endif %}
echo "==> Starting php-fpm and nginx..."
php-fpm -D
exec nginx -g "daemon off;"
