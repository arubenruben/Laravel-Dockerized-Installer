#!/bin/sh
# Laravel + Inertia.js — Docker entrypoint
# Generated by Laravel Dockerized Installer
set -e

# ── 1. Install / update PHP dependencies ────────────────────────────────────
echo "==> Installing Composer dependencies..."
composer install --optimize-autoloader --no-interaction --no-progress --no-ansi

{% if db == 'sqlite' %}
# ── 2. Ensure the SQLite database file exists ────────────────────────────────
mkdir -p database
touch database/database.sqlite

# ── 3. Run migrations ────────────────────────────────────────────────────────
echo "==> Running database migrations..."
php artisan migrate --force --no-interaction

{% else %}
# ── 2 & 3. Wait for the database, then migrate ───────────────────────────────
echo "==> Waiting for the database to be ready..."
MAX_RETRIES=30
ATTEMPT=0
until php artisan migrate --force --no-interaction; do
    ATTEMPT=$((ATTEMPT + 1))
    if [ "$ATTEMPT" -ge "$MAX_RETRIES" ]; then
        echo "ERROR: Database not reachable after ${MAX_RETRIES} attempts. Exiting."
        exit 1
    fi
    echo "    Not ready yet, retrying in 3 s... (${ATTEMPT}/${MAX_RETRIES})"
    sleep 3
done

{% endif %}
# ── 4. Wait for the Vite dev server to come up ───────────────────────────────
echo "==> Waiting for the Vite dev server..."
MAX_RETRIES=60
ATTEMPT=0
until [ -f public/hot ]; do
    ATTEMPT=$((ATTEMPT + 1))
    if [ "$ATTEMPT" -ge "$MAX_RETRIES" ]; then
        echo "WARNING: Vite dev server not ready after ${MAX_RETRIES} attempts. Starting anyway."
        break
    fi
    sleep 2
done

echo "==> Starting Laravel development server..."
exec php artisan serve --host=0.0.0.0 --port=8000
