# Laravel {{ laravel_version }} — Docker Compose stack
services:
  app:
    build: .
    container_name: laravel_app
    restart: unless-stopped
    working_dir: /var/www/html
    ports:
      - "{{ app_port }}:8000"
    volumes:
      - .:/var/www/html
    depends_on:
{% if db != 'sqlite' %}
      - db
{% endif %}
      - redis
    environment:
      APP_ENV: local
      APP_KEY: ""
{% if db == 'mysql' %}
      DB_CONNECTION: mysql
      DB_HOST: db
      DB_PORT: 3306
      DB_DATABASE: laravel
      DB_USERNAME: laravel
      DB_PASSWORD: secret
{% elif db == 'postgres' %}
      DB_CONNECTION: pgsql
      DB_HOST: db
      DB_PORT: 5432
      DB_DATABASE: laravel
      DB_USERNAME: laravel
      DB_PASSWORD: secret
{% else %}
      DB_CONNECTION: sqlite
      DB_DATABASE: /var/www/html/database/database.sqlite
{% endif %}
      REDIS_HOST: redis
      CACHE_DRIVER: redis
      SESSION_DRIVER: redis
      QUEUE_CONNECTION: redis


{% if db == 'mysql' %}
  db:
    image: mysql:8.0
    container_name: laravel_db
    restart: unless-stopped
    environment:
      MYSQL_DATABASE: laravel
      MYSQL_USER: laravel
      MYSQL_PASSWORD: secret
      MYSQL_ROOT_PASSWORD: rootsecret
    ports:
      - "3306:3306"
    volumes:
      - db_data:/var/lib/mysql
{% elif db == 'postgres' %}
  db:
    image: postgres:16-alpine
    container_name: laravel_db
    restart: unless-stopped
    environment:
      POSTGRES_DB: laravel
      POSTGRES_USER: laravel
      POSTGRES_PASSWORD: secret
    ports:
      - "5432:5432"
    volumes:
      - db_data:/var/lib/postgresql/data
{% endif %}

  redis:
    image: redis:7-alpine
    container_name: laravel_redis
    restart: unless-stopped
    ports:
      - "6379:6379"

{% if db != 'sqlite' %}
volumes:
  db_data:
{% endif %}
