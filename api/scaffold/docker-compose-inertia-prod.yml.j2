# Laravel + Inertia.js ({{ starter_kit | replace('-', ' ') | title }}) — production stack
# Runs the image built by `docker build .` (php-fpm + nginx, assets pre-built).
# No source bind mount, no Vite sidecar — set secrets via shell-exported env vars.
services:
  app:
    build: .
    container_name: {{ app_slug }}_app_prod
    restart: unless-stopped
    ports:
      - "${APP_PORT:-8000}:80"
    depends_on:
{% if db != 'sqlite' %}
      - db
{% endif %}
    environment:
      APP_ENV: production
      APP_DEBUG: "false"
      APP_KEY: ${APP_KEY}
{% if db == 'mysql' %}
      DB_CONNECTION: mysql
      DB_HOST: db
      DB_PORT: 3306
      DB_DATABASE: laravel
      DB_USERNAME: laravel
      DB_PASSWORD: ${DB_PASSWORD}
{% elif db == 'postgres' %}
      DB_CONNECTION: pgsql
      DB_HOST: db
      DB_PORT: 5432
      DB_DATABASE: laravel
      DB_USERNAME: laravel
      DB_PASSWORD: ${DB_PASSWORD}
{% else %}
      DB_CONNECTION: sqlite
      DB_DATABASE: /var/www/html/database/database.sqlite
{% endif %}
    healthcheck:
      test: ["CMD", "curl", "-f", "http://localhost/up"]
      interval: 30s
      timeout: 10s
      retries: 3
      start_period: 40s

{% if db == 'mysql' %}
  db:
    image: mysql:8.0
    container_name: {{ app_slug }}_db_prod
    restart: unless-stopped
    environment:
      MYSQL_DATABASE: laravel
      MYSQL_USER: laravel
      MYSQL_PASSWORD: ${DB_PASSWORD}
      MYSQL_ROOT_PASSWORD: ${DB_ROOT_PASSWORD}
    volumes:
      - db_data_prod:/var/lib/mysql
    healthcheck:
      test: ["CMD", "mysqladmin", "ping", "-h", "localhost", "-u", "laravel", "-p${DB_PASSWORD}"]
      interval: 10s
      timeout: 5s
      retries: 5
      start_period: 30s
{% elif db == 'postgres' %}
  db:
    image: postgres:16-alpine
    container_name: {{ app_slug }}_db_prod
    restart: unless-stopped
    environment:
      POSTGRES_DB: laravel
      POSTGRES_USER: laravel
      POSTGRES_PASSWORD: ${DB_PASSWORD}
    volumes:
      - db_data_prod:/var/lib/postgresql/data
    healthcheck:
      test: ["CMD", "pg_isready", "-U", "laravel", "-d", "laravel"]
      interval: 10s
      timeout: 5s
      retries: 5
      start_period: 30s
{% endif %}

{% if db != 'sqlite' %}
volumes:
  db_data_prod:
{% endif %}
