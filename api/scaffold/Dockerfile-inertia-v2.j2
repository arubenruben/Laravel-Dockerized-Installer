FROM php:{{ php_version }}-fpm-alpine

RUN apk add --no-cache \
    bash curl zip unzip git nginx nodejs npm libpng-dev libjpeg-turbo-dev freetype-dev \
    oniguruma-dev libxml2-dev && \
    docker-php-ext-configure gd --with-freetype --with-jpeg && \
{% if db == 'mysql' %}
    docker-php-ext-install pdo pdo_mysql mbstring gd xml bcmath opcache
{% elif db == 'postgres' %}
    apk add --no-cache postgresql-dev && \
    docker-php-ext-install pdo pdo_pgsql mbstring gd xml bcmath opcache
{% else %}
    apk add --no-cache sqlite-dev && \
    docker-php-ext-install pdo pdo_sqlite mbstring gd xml bcmath opcache
{% endif %}

COPY --from=composer:2 /usr/bin/composer /usr/bin/composer
COPY docker/nginx.conf /etc/nginx/http.d/default.conf

WORKDIR /var/www/html
COPY . .

RUN composer install --optimize-autoloader --no-dev --no-interaction

# A throwaway .env (removed before the layer ends) lets Laravel boot during
# `npm run build` — the Wayfinder Vite plugin needs a running app to
# generate its typed route helpers.
RUN cp .env.example .env && php artisan key:generate --ansi --force && \
    npm install && npm run build && rm -f .env

RUN chown -R www-data:www-data storage bootstrap/cache

# Storage/bootstrap dirs are created by the entrypoint at runtime after
# the volume mount is in place. Invoked via `sh` (not directly) because the
# bind mount in docker-compose.yml replaces this file with the host copy at
# runtime, and zip extraction on some platforms (notably Windows) drops the
# executable bit — running it as an argument to `sh` avoids depending on it.
RUN chmod +x docker/dev.entrypoint.sh docker/prod.entrypoint.sh

EXPOSE 80
CMD ["sh", "docker/prod.entrypoint.sh"]
