APP_NAME={{ app_name }}
APP_ENV=local
APP_KEY={{ app_key | default('') }}
APP_DEBUG=true
APP_URL=http://localhost:{{ app_port }}

LOG_CHANNEL=stack

{% if db == 'mysql' %}
DB_CONNECTION=mysql
DB_HOST=db
DB_PORT=3306
DB_DATABASE=laravel
DB_USERNAME=laravel
DB_PASSWORD=secret
{% elif db == 'postgres' %}
DB_CONNECTION=pgsql
DB_HOST=db
DB_PORT=5432
DB_DATABASE=laravel
DB_USERNAME=laravel
DB_PASSWORD=secret
{% else %}
DB_CONNECTION=sqlite
DB_DATABASE=/var/www/html/database/database.sqlite
{% endif %}

BROADCAST_DRIVER=log
CACHE_DRIVER=redis
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis
SESSION_DRIVER=redis
SESSION_LIFETIME=120

REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379
