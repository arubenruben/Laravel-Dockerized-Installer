# Laravel + Inertia.js ({{ starter_kit | replace('-', ' ') | title }}) — Docker Compose stack
services:
  app:
    build: .
    container_name: laravel_app
    restart: unless-stopped
    working_dir: /var/www/html
    ports:
      - "{{ app_port }}:8000"
    volumes:
      - .:/var/www/html
    depends_on:
{% if db != 'sqlite' %}
      - db
{% endif %}
    environment:
      APP_ENV: local
{% if db == 'mysql' %}
      DB_CONNECTION: mysql
      DB_HOST: db
      DB_PORT: 3306
      DB_DATABASE: laravel
      DB_USERNAME: laravel
      DB_PASSWORD: secret
{% elif db == 'postgres' %}
      DB_CONNECTION: pgsql
      DB_HOST: db
      DB_PORT: 5432
      DB_DATABASE: laravel
      DB_USERNAME: laravel
      DB_PASSWORD: secret
{% else %}
      DB_CONNECTION: sqlite
      DB_DATABASE: /var/www/html/database/database.sqlite
{% endif %}
      VITE_DEV_SERVER_HOST: 0.0.0.0
    healthcheck:
      test: ["CMD", "curl", "-f", "http://localhost:8000/up"]
      interval: 30s
      timeout: 10s
      retries: 3
      start_period: 40s

  vite:
    image: php:{{ php_version }}-cli-alpine
    container_name: laravel_vite
    restart: unless-stopped
    working_dir: /var/www/html
    command: >
      sh -c "apk add --no-cache nodejs npm &&
             npm install &&
             npm run dev -- --host"
    ports:
      - "5173:5173"
    volumes:
      - .:/var/www/html
      # node_modules lives in its own volume instead of the bind mount so npm
      # writes to the container's native filesystem. Bind-mounting node_modules
      # directly is unreliable across hosts (Docker Desktop's virtualized FS on
      # Windows/macOS can return EPERM on files under a large bind-mounted tree).
      - vite_node_modules:/var/www/html/node_modules
    healthcheck:
      test: ["CMD-SHELL", "wget -q --spider http://localhost:5173 || exit 1"]
      interval: 30s
      timeout: 10s
      retries: 3
      start_period: 60s
    depends_on:
      app:
        condition: service_healthy

{% if db == 'mysql' %}
  db:
    image: mysql:8.0
    container_name: laravel_db
    restart: unless-stopped
    environment:
      MYSQL_DATABASE: laravel
      MYSQL_USER: laravel
      MYSQL_PASSWORD: secret
      MYSQL_ROOT_PASSWORD: rootsecret
    ports:
      - "3306:3306"
    volumes:
      - db_data:/var/lib/mysql
    healthcheck:
      test: ["CMD", "mysqladmin", "ping", "-h", "localhost", "-u", "laravel", "-psecret"]
      interval: 10s
      timeout: 5s
      retries: 5
      start_period: 30s
{% elif db == 'postgres' %}
  db:
    image: postgres:16-alpine
    container_name: laravel_db
    restart: unless-stopped
    environment:
      POSTGRES_DB: laravel
      POSTGRES_USER: laravel
      POSTGRES_PASSWORD: secret
    ports:
      - "5432:5432"
    volumes:
      - db_data:/var/lib/postgresql/data
    healthcheck:
      test: ["CMD", "pg_isready", "-U", "laravel", "-d", "laravel"]
      interval: 10s
      timeout: 5s
      retries: 5
      start_period: 30s
{% endif %}

volumes:
  vite_node_modules:
{% if db != 'sqlite' %}
  db_data:
{% endif %}
